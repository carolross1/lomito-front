<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp" android:background="@color/background">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🏠 Refugios cercanos" android:textSize="20sp" android:textStyle="bold"
        android:textColor="@color/primary" android:layout_marginBottom="12dp"/>
    <TextView android:id="@+id/tvEmpty" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="No hay refugios registrados"
        android:gravity="center" android:textColor="@color/text_secondary" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvRefugios"
        android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>
