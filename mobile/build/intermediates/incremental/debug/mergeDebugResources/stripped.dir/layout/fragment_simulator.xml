<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📡 Simulador BLE" android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/simulador_color" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Simula la distancia del collar BLE al Watch"
            android:textColor="@color/text_secondary" android:layout_marginBottom="20dp"/>

        <TextView android:id="@+id/tvSinMascotas" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="No hay mascotas registradas"
            android:gravity="center" android:textColor="@color/text_secondary"
            android:visibility="gone"/>

        <LinearLayout android:id="@+id/layoutSimulator" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Selecciona mascota:" android:textColor="@color/text_primary"
                android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <Spinner android:id="@+id/spinnerMascota" android:layout_width="match_parent"
                android:layout_height="48dp" android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp" app:cardElevation="4dp"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Distancia simulada" android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvDistanciaActual" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0m" android:textSize="48sp"
                        android:textStyle="bold" android:textColor="@color/primary"/>
                    <TextView android:id="@+id/tvUmbral" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Umbral de alerta: 50m"
                        android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.slider.Slider android:id="@+id/sliderDistancia"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:thumbColor="@color/primary" app:trackColor="@color/primary_light"
                app:labelBehavior="floating"/>

            <com.google.android.material.card.MaterialCardView android:id="@+id/cardEstado"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="8dp" app:cardElevation="2dp" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/tvEstadoSimulacion" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:padding="16dp"
                    android:gravity="center" android:textStyle="bold" android:textSize="16sp"
                    android:text="Mueve el slider para simular"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton android:id="@+id/btnEnviarAlerta"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="🚨 Enviar alerta al Watch ahora"
                android:backgroundTint="@color/alerta_rojo" android:textColor="@android:color/white"
                android:textSize="16sp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
