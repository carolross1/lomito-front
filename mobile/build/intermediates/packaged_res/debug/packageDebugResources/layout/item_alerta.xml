<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila superior: Icono + Título + Estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvIcono"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="📢"
                android:textSize="18sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Título"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLeida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● No leída"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Mensaje -->
        <TextView
            android:id="@+id/tvMensaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="40dp"
            android:text="Mensaje de la notificación"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Fila inferior: Fecha + Botón -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="01/01/2024 12:00"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp" />

            <!-- ✅ Botón Marcar como leída -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarcarLeida"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:paddingHorizontal="12dp"
                android:text="✓ Leer"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="visible"
                app:backgroundTint="@color/accent_blue"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>